{
  "manifest_version": 3,
  "name": "Conscious",
  "description": "Gain control over your YouTube consumption.",
  "version": "0.0.1",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {
    "default_title": "Conscious",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
