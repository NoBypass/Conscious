{
  "manifest_version": 3,
  "name": "Conscious",
  "description": "Gain control over your YouTube consumption.",
  "version": "0.0.2",
  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {
    "default_title": "Conscious"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["src/inpage.css"],
      "js": [
        "src/content/shared.js",
        "src/content/storage.js",
        "src/content/shorts.js",
        "src/content/daily-timer.js",
        "src/content/header-declutter.js",
        "src/content/watch-history.js",
        "src/content.js",
        "src/inpage-ui.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
